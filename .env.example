# Discord bot token from the developer portal
DISCORD_TOKEN=

# Spotify app credentials, needed for playlist/track metadata lookup
# get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# optional overrides, defaults are fine for most setups
DB_PATH=db/musicbot.sqlite3
MAX_QUEUE_SIZE=0
SPOTIFY_MATCH_SEARCH_DEPTH=5

# discord user ids that skip the playback vote, comma separated.
# example: VOTE_BYPASS_USER_IDS=111111111111111111,222222222222222222
VOTE_BYPASS_USER_IDS=
